#  before PyInstaller builds the exe, so they can be ignored.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nosetests
.pytest_cache/
.mypy_cache/
.ruff_cache/
vcache/
.ipynb_checkpoints

# Environment variables
.env
.env.*
!.env.template

# Virtual environment
venv/
.venv/
env/
ENV/

# Project-specific paths
data/
experiments/
logs/*
!logs/training/
!logs/api/
!logs/preprocessing/
!logs/errors/
!logs/.gitkeep

